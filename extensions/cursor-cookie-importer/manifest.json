{
  "manifest_version": 3,
  "name": "Sub2API Cursor Cookie Importer",
  "description": "Imports the single Cursor _vcrcs cookie only after an explicit request from an authorized Sub2API page.",
  "version": "0.34.5",
  "permissions": ["alarms", "cookies", "scripting", "storage"],
  "host_permissions": ["https://cursor.com/*"],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.poke2api.com/*",
        "https://www.pokeapi.top/*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["shared.js", "page-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
